# ============================================================
# Agente Local de Impresión — Print QR System
# Copia este archivo como .env y completa los valores
# ============================================================

# Supabase (usa SUPABASE_SERVICE_ROLE_KEY, no la clave anon)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Polling: con qué frecuencia buscar trabajos nuevos (ms)
# 5000 = cada 5 segundos  |  3000 = cada 3 segundos
POLLING_INTERVAL_MS=5000

# Reintentos antes de marcar un trabajo como fallido
MAX_RETRIES=3

# Minutos sin actualización para considerar un trabajo atascado en "printing"
STUCK_TIMEOUT_MIN=10

# Directorios (relativo al directorio del agente)
TEMP_DIR=./tmp
LOG_DIR=./logs
